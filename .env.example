# Database
DATABASE_URL=postgresql://looksphishy:looksphishy@localhost:5433/looksphishy

# Redis (BullMQ)
REDIS_URL=redis://localhost:6380

# API
PORT=3001
CORS_ORIGIN=http://localhost:4321

# Cloudflare Turnstile
# Get keys at https://dash.cloudflare.com/turnstile
# Test keys: site=1x00000000000000000000AA secret=1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Webhook auth (min 16 chars, generate with: openssl rand -hex 16)
WEBHOOK_SECRET=change-me-in-production

# Plunk (user-facing transactional email, self-hosted)
PLUNK_API_KEY=
PLUNK_API_URL=https://plunk.yourdomain.com/api/v1

# AWS SES (abuse report emails - use a dedicated subdomain like reports.looksphishy.org)
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_ADDRESS=reports@reports.looksphishy.org

# Cloudflare Abuse Reports (for Cloudflare-proxied phishing sites)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Google Web Risk (browser-level phishing blocking in Chrome/Firefox/Safari)
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_WEB_RISK_API_KEY=

# Verification service
VERIFICATION_API_URL=http://localhost:3002
VERIFICATION_API_KEY=change-me-in-production
