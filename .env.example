# Database
DATABASE_URL=postgresql://looksphishy:looksphishy@localhost:5433/looksphishy

# Redis (BullMQ)
REDIS_URL=redis://localhost:6380

# API
PORT=3001
CORS_ORIGIN=http://localhost:4321

# Cloudflare Turnstile
# Get keys at https://dash.cloudflare.com/turnstile
# Test keys: site=1x00000000000000000000AA secret=1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# urlscan.io (optional, leave empty for stub verification)
URLSCAN_API_KEY=

# Webhook auth (min 16 chars, generate with: openssl rand -hex 16)
WEBHOOK_SECRET=change-me-in-production
