---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import { buttonVariants } from "@looksphishy/ui";
import { ReportForm } from "../components/ReportForm";
---

<Base title="LooksPhishy — Report once. Protect everyone.">

  <Header />

  <!-- ===== HERO ===== -->
  <section class="hero-section relative overflow-hidden px-6 pb-32 pt-24 sm:pt-32 lg:pb-48">
    <div class="hero-bg absolute inset-0 -z-10"></div>

    <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Left: text -->
      <div>
        <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-sm text-sky-200">
          Open source &amp; free forever
        </div>

        <h1 class="mt-6 text-4xl font-extrabold leading-[1.1] tracking-tight text-white sm:text-5xl lg:text-6xl">
          Report once.<br />
          <span class="text-sky-300">Protect everyone.</span>
        </h1>

        <p class="mt-5 max-w-md text-lg leading-relaxed text-sky-100/90">
          Spot a phishing URL? Report it once and we relay it to Google Safe Browsing, Cloudflare, and other security providers.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-4">
          <button
            onclick="document.getElementById('how-it-works').scrollIntoView({behavior:'smooth'})"
            class="group inline-flex h-11 items-center gap-2 rounded-lg border border-white/15 bg-white/5 px-6 text-sm font-medium text-sky-100 transition-colors hover:border-white/25 hover:bg-white/10"
          >
            See how it works
            <svg class="size-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </button>
          <a
            href="https://github.com/looksphishy/looksphishy"
            class="inline-flex h-11 items-center gap-2 rounded-lg border border-white/15 bg-white/5 px-6 text-sm font-medium text-sky-100 transition-colors hover:border-white/25 hover:bg-white/10"
          >
            <svg class="size-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
        </div>
      </div>

      <!-- Right: form -->
      <div class="w-full max-w-md lg:ml-auto">
        <ReportForm client:load />
      </div>
    </div>

    <!-- Wave divider -->
    <div class="absolute -bottom-px left-0 right-0">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="block w-full" preserveAspectRatio="none">
        <path d="M0 120L1440 120L1440 60C1440 60 1320 0 1140 20C960 40 840 80 660 80C480 80 360 20 180 30C90 35 0 60 0 60L0 120Z" fill="var(--background)" />
      </svg>
    </div>
  </section>

  <!-- ===== FAN-OUT VISUALIZATION ===== -->
  <section id="how-it-works" class="relative bg-background px-6 pb-24 pt-16">
    <div class="mx-auto max-w-5xl">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary">How it works</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground sm:text-5xl">
          One report. Five+ destinations.
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-muted-foreground">
          You shouldn't have to fill out five forms to report one phishing site. LooksPhishy takes your single report, verifies it, and relays it everywhere that matters.
        </p>
      </div>

      <!-- Fan-out diagram -->
      <div class="mt-16 flex flex-col items-center gap-0">
        <!-- Source -->
        <div class="relative z-10 flex items-center gap-3 rounded-2xl border border-border bg-card px-6 py-4">
          <div class="flex size-10 items-center justify-center rounded-xl bg-primary/10 text-xl">🐟</div>
          <div>
            <div class="text-sm font-semibold text-foreground">Your report</div>
            <div class="text-xs text-muted-foreground">One suspicious URL</div>
          </div>
        </div>

        <!-- Connector lines -->
        <div class="relative flex h-24 w-full max-w-3xl items-center justify-center">
          <svg class="absolute inset-0 h-full w-full" viewBox="0 0 800 96" fill="none" preserveAspectRatio="xMidYMid meet">
            <!-- Static lines -->
            <path d="M400 0 L400 48" stroke="var(--primary)" stroke-width="2" stroke-dasharray="4 4" opacity="0.4" />
            <path d="M400 48 L100 96" stroke="var(--primary)" stroke-width="2" stroke-dasharray="4 4" opacity="0.4" />
            <path d="M400 48 L250 96" stroke="var(--primary)" stroke-width="2" stroke-dasharray="4 4" opacity="0.4" />
            <path d="M400 48 L400 96" stroke="var(--primary)" stroke-width="2" stroke-dasharray="4 4" opacity="0.4" />
            <path d="M400 48 L550 96" stroke="var(--primary)" stroke-width="2" stroke-dasharray="4 4" opacity="0.4" />
            <path d="M400 48 L700 96" stroke="var(--primary)" stroke-width="2" stroke-dasharray="4 4" opacity="0.4" />
            <!--
              3s cycle:
              0.0–1.0s  trunk dot travels down (keyTimes 0–0.33)
              1.0–2.0s  5 dots fan out to destinations (keyTimes 0.33–0.67)
              2.0–3.0s  pause before repeat (keyTimes 0.67–1)
            -->
            <!-- Trunk dot -->
            <circle r="4" fill="var(--primary)">
              <animateMotion dur="3s" repeatCount="indefinite" path="M400 0 L400 48" keyPoints="0;1;1" keyTimes="0;0.33;1" calcMode="linear" />
              <animate attributeName="opacity" dur="3s" repeatCount="indefinite" values="1;1;0;0" keyTimes="0;0.32;0.34;1" />
            </circle>
            <!-- Fan-out dots: hold at junction, then travel, then hold at end -->
            <circle r="3" fill="var(--primary)">
              <animateMotion dur="3s" repeatCount="indefinite" path="M400 48 L100 96" keyPoints="0;0;1;1" keyTimes="0;0.33;0.67;1" calcMode="linear" />
              <animate attributeName="opacity" dur="3s" repeatCount="indefinite" values="0;0;1;1;0;0" keyTimes="0;0.32;0.34;0.66;0.68;1" />
            </circle>
            <circle r="3" fill="var(--primary)">
              <animateMotion dur="3s" repeatCount="indefinite" path="M400 48 L250 96" keyPoints="0;0;1;1" keyTimes="0;0.33;0.67;1" calcMode="linear" />
              <animate attributeName="opacity" dur="3s" repeatCount="indefinite" values="0;0;1;1;0;0" keyTimes="0;0.32;0.34;0.66;0.68;1" />
            </circle>
            <circle r="3" fill="var(--primary)">
              <animateMotion dur="3s" repeatCount="indefinite" path="M400 48 L400 96" keyPoints="0;0;1;1" keyTimes="0;0.33;0.67;1" calcMode="linear" />
              <animate attributeName="opacity" dur="3s" repeatCount="indefinite" values="0;0;1;1;0;0" keyTimes="0;0.32;0.34;0.66;0.68;1" />
            </circle>
            <circle r="3" fill="var(--primary)">
              <animateMotion dur="3s" repeatCount="indefinite" path="M400 48 L550 96" keyPoints="0;0;1;1" keyTimes="0;0.33;0.67;1" calcMode="linear" />
              <animate attributeName="opacity" dur="3s" repeatCount="indefinite" values="0;0;1;1;0;0" keyTimes="0;0.32;0.34;0.66;0.68;1" />
            </circle>
            <circle r="3" fill="var(--primary)">
              <animateMotion dur="3s" repeatCount="indefinite" path="M400 48 L700 96" keyPoints="0;0;1;1" keyTimes="0;0.33;0.67;1" calcMode="linear" />
              <animate attributeName="opacity" dur="3s" repeatCount="indefinite" values="0;0;1;1;0;0" keyTimes="0;0.32;0.34;0.66;0.68;1" />
            </circle>
          </svg>
        </div>

        <!-- Destination nodes -->
        <div class="grid w-full max-w-3xl grid-cols-3 gap-3 sm:grid-cols-5">
          {[
            { name: "Google", sub: "Safe Browsing" },
            { name: "Cloudflare", sub: "Radar" },
            { name: "APWG", sub: "eCrime" },
            { name: "PhishTank", sub: "Community" },
            { name: "More...", sub: "Growing list" },
          ].map((provider) => (
            <div class="flex flex-col items-center gap-2 rounded-xl border border-border bg-card p-4 text-center">
              <div class="flex size-8 items-center justify-center rounded-lg bg-primary/10 text-xs font-bold text-primary">
                {provider.name.charAt(0)}
              </div>
              <div>
                <div class="text-xs font-semibold text-foreground">{provider.name}</div>
                <div class="text-[10px] text-muted-foreground">{provider.sub}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FEATURES ===== -->
  <section class="bg-secondary/30 px-6 py-24">
    <div class="mx-auto grid max-w-5xl gap-6 sm:grid-cols-3">
      {[
        {
          icon: `<svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
          title: "Auto-verified",
          desc: "Every URL is checked against threat intelligence feeds before relay. No false positives wasting provider time.",
        },
        {
          icon: `<svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
          title: "Instant relay",
          desc: "Reports are queued and dispatched in seconds. Background workers handle the fan-out so nothing blocks or drops.",
        },
        {
          icon: `<svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>`,
          title: "Fully open source",
          desc: "Every line of code is public. Audit it, fork it, self-host it. This is a community tool, not a product.",
        },
      ].map((feature) => (
        <div class="rounded-2xl border border-border bg-card p-8">
          <div class="mb-4 inline-flex size-12 items-center justify-center rounded-xl bg-primary/10 text-primary" set:html={feature.icon} />
          <h3 class="text-lg font-semibold text-foreground">{feature.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{feature.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== EMAIL FORWARDING ===== -->
  <section class="relative overflow-hidden px-6 py-24">
    <div class="email-section-bg absolute inset-0 -z-10"></div>
    <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-2 lg:gap-20">
      <!-- Left: copy -->
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest text-sky-300">Email forwarding</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Just forward the email.
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-sky-100/80">
          Got a phishing email? Don't bother copying the URL. Forward the entire email
          to <span class="font-semibold text-sky-200">this@looksphishy.org</span> and
          we'll handle the rest.
        </p>
        <ul class="mt-6 space-y-3 text-sm text-sky-100/80">
          <li class="flex items-start gap-3">
            <svg class="mt-0.5 size-4 shrink-0 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            URLs are extracted from the email body and headers automatically
          </li>
          <li class="flex items-start gap-3">
            <svg class="mt-0.5 size-4 shrink-0 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Works from any email client — Gmail, Outlook, Apple Mail, anything
          </li>
          <li class="flex items-start gap-3">
            <svg class="mt-0.5 size-4 shrink-0 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Each URL is verified, then relayed to all providers
          </li>
        </ul>
      </div>

      <!-- Right: mock email UI -->
      <div class="w-full max-w-md lg:ml-auto">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-1">
          <!-- Email chrome -->
          <div class="flex items-center gap-1.5 border-b border-white/5 px-4 py-3">
            <div class="size-2.5 rounded-full bg-white/10"></div>
            <div class="size-2.5 rounded-full bg-white/10"></div>
            <div class="size-2.5 rounded-full bg-white/10"></div>
          </div>
          <div class="space-y-3 p-5">
            <!-- To field -->
            <div class="flex items-center gap-2 text-xs">
              <span class="text-sky-200/70">To:</span>
              <span class="rounded-md bg-sky-400/10 px-2 py-0.5 font-mono text-sky-300">this@looksphishy.org</span>
            </div>
            <!-- Subject -->
            <div class="flex items-center gap-2 text-xs">
              <span class="text-sky-200/70">Subject:</span>
              <span class="text-sky-100/90">Fwd: Verify your account immediately</span>
            </div>
            <!-- Divider -->
            <div class="border-t border-white/5"></div>
            <!-- Body -->
            <div class="space-y-2 text-xs leading-relaxed text-sky-100/70">
              <p>---------- Forwarded message ----------</p>
              <p>From: security@bankofamerica-verify.com</p>
              <p>Subject: Verify your account immediately</p>
              <p class="pt-1 text-sky-100/80">Dear Customer, your account has been limited. Please verify your identity at
                <span class="rounded bg-red-500/10 px-1 py-0.5 font-mono text-red-400">http://bankofamerica-verify.com/login</span>
              </p>
            </div>
            <!-- Status bar -->
            <div class="flex items-center gap-2 rounded-lg bg-sky-400/10 px-3 py-2 text-xs">
              <svg class="size-3.5 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span class="text-sky-300">1 URL extracted &middot; Verified &middot; Relayed to 5 providers</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FOR DEVELOPERS ===== -->
  <section class="bg-background px-6 py-24">
    <div class="mx-auto max-w-5xl">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary">For developers</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          Integrate with your tools
        </h2>
        <p class="mt-4 text-lg text-muted-foreground">
          Use the API to report URLs from your own security tooling, browser extensions, or abuse pipelines.
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-2xl overflow-hidden rounded-2xl border border-border">
        <!-- Code block header -->
        <div class="flex items-center gap-2 border-b border-border bg-muted/50 px-4 py-2.5">
          <div class="size-2.5 rounded-full bg-border"></div>
          <div class="size-2.5 rounded-full bg-border"></div>
          <div class="size-2.5 rounded-full bg-border"></div>
          <span class="ml-2 text-xs text-muted-foreground">report.sh</span>
        </div>
        <!-- Code content -->
        <div class="bg-card p-5">
          <pre class="text-sm leading-relaxed"><code class="text-muted-foreground"><span class="text-primary">curl</span> -X POST https://api.looksphishy.org/report \
  -H <span class="text-foreground">"Content-Type: application/json"</span> \
  -d <span class="text-foreground">'{"{"}"url": "https://suspicious-site.com/login"{"}"}'</span></code></pre>
        </div>
      </div>

      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        {[
          { title: "No API key needed", desc: "Public reporting endpoint. No sign-up, no rate limit headaches." },
          { title: "Batch support", desc: "Submit multiple URLs in one request for bulk reporting." },
          { title: "Status callbacks", desc: "Get notified when your report has been verified and relayed." },
        ].map((item) => (
          <div class="rounded-xl border border-border bg-card p-5">
            <h3 class="text-sm font-semibold text-foreground">{item.title}</h3>
            <p class="mt-1 text-sm text-muted-foreground">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>



  <!-- ===== CTA ===== -->
  <section class="relative overflow-hidden px-6 py-24">
    <div class="cta-bg absolute inset-0 -z-10"></div>
    <div class="mx-auto max-w-2xl text-center">
      <div class="text-5xl">🐟</div>
      <h2 class="mt-4 text-3xl font-bold tracking-tight text-white sm:text-4xl">
        If it looks phishy, report it.
      </h2>
      <p class="mx-auto mt-4 max-w-md text-lg text-sky-100/90">
        Help make the internet safer. Every report counts.
      </p>
      <div class="mt-8">
        <a
          href="https://github.com/looksphishy/looksphishy"
          class="inline-flex h-12 items-center gap-2.5 rounded-xl bg-white px-8 text-base font-semibold text-gray-900 transition-colors hover:bg-sky-50"
        >
          <svg class="size-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Star on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="border-t border-border bg-background px-6 py-8">
    <div class="mx-auto flex max-w-5xl items-center justify-between text-sm text-muted-foreground">
      <div class="flex items-center gap-2">
        <span>🐟</span>
        <span>LooksPhishy</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="/privacy" class="transition-colors hover:text-foreground">Privacy</a>
        <a href="https://github.com/looksphishy/looksphishy" class="transition-colors hover:text-foreground">GitHub</a>
      </div>
    </div>
  </footer>
</Base>

<style>
  .hero-bg {
    background: radial-gradient(ellipse 80% 60% at 50% 40%, oklch(0.28 0.09 230), oklch(0.12 0.05 240) 70%, oklch(0.08 0.03 250));
  }
  .email-section-bg {
    background: radial-gradient(ellipse 90% 70% at 40% 50%, oklch(0.22 0.07 235), oklch(0.12 0.05 240) 70%, oklch(0.08 0.03 250));
  }
  .cta-bg {
    background: radial-gradient(ellipse 80% 70% at 50% 50%, oklch(0.28 0.09 230), oklch(0.12 0.05 240) 70%, oklch(0.08 0.03 250));
  }
</style>
