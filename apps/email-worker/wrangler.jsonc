{
	"name": "looksphishy-email-worker",
	"main": "src/index.ts",
	"compatibility_date": "2026-01-14",
	"compatibility_flags": ["nodejs_compat_v2"],
	// WEBHOOK_SECRET must be set via: wrangler secret put WEBHOOK_SECRET
	"vars": {
		"API_URL": "https://api.looksphishy.org"
	},
	"observability": {
		"enabled": true
	}
}
